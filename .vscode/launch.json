{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug ccpdbg",
			"type": "cppvsdbg",
			"request": "launch",
			"args": [
				"-r",
				"~/projects/test/server"
			],
			"program": "${workspaceRoot}/target/debug/iceserver.exe",
			"cwd": "${workspaceFolder}",
			"preLaunchTask": "cargo build"
		},
		{
			"name": "Debug lldb",
			"type": "lldb",
			"request": "launch",
			"cargo": {
				"args": [
					"run",
					"--bin=iceserver"
				]
			},
			"args": [
				"-r",
				"~/projects/test/server/server.toml"
			]
		}
	]
}